{
  "name": "nido",
  "version": "1.0.0",
  "description": "Mobile-first expense tracking app for couples",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "build": "tsc -p server && vite build",
    "preview": "npm run build && npm run server:start",
    "server:dev": "tsx watch server/index.ts",
    "server:start": "node dist/server/index.js",
    "client:dev": "vite",
    "client:build": "vite build"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "date-fns": "^2.29.3",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.1",
    "@types/node": "^18.11.18",
    "@types/react": "^18.0.26",
    "@types/react-dom": "^18.0.9",
    "@vitejs/plugin-react": "^3.1.0",
    "concurrently": "^7.6.0",
    "tsx": "^3.12.2",
    "typescript": "^4.9.4",
    "vite": "^4.0.0",
    "vite-plugin-pwa": "^0.14.1"
  }
}
