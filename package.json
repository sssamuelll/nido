{
  "name": "nido",
  "version": "1.0.0",
  "description": "Mobile-first expense tracking app for couples",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "build": "tsc -p server && vite build",
    "preview": "npm run build && npm run server:start",
    "server:dev": "tsx watch server/index.ts",
    "server:start": "node dist/server/index.js",
    "client:dev": "vite",
    "client:build": "vite build",
    "deploy": "bash scripts/deploy.sh",
    "setup-env": "node scripts/setup-env.js",
    "validate-env": "tsx -r dotenv/config server/config.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "test:ci": "vitest run --exclude=src/components/**"
  },
  "dependencies": {
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^2.29.3",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "lucide-react": "^0.577.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.6",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/bcryptjs": "^2.4.2",
    "@types/better-sqlite3": "^7.6.8",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.13",
    "@types/csurf": "^1.11.5",
    "@types/express": "^4.17.17",
    "@types/helmet": "^0.0.48",
    "@types/node": "^18.11.18",
    "@types/react": "^18.0.26",
    "@types/react-dom": "^18.0.9",
    "@types/supertest": "^2.0.12",
    "@vitejs/plugin-react": "^3.1.0",
    "@vitest/ui": "^1.6.0",
    "concurrently": "^7.6.0",
    "happy-dom": "^20.8.9",
    "jsdom": "^24.0.0",
    "supertest": "^6.3.3",
    "tsx": "^3.12.2",
    "typescript": "^4.9.4",
    "vite": "^4.0.0",
    "vite-plugin-pwa": "^0.14.1",
    "vitest": "^1.6.0"
  }
}
