# Nido Environment Configuration
# Copy this file to .env and fill in values

# === Server configuration ===

NODE_ENV=development
PORT=3100
APP_BASE_URL=http://localhost:3100
# Comma-separated list of allowed CORS origins.
# Required in production — without it, all cross-origin requests are rejected.
# ALLOWED_ORIGINS=https://nido.example.com
APP_SESSION_DAYS=30
APP_SESSION_COOKIE_NAME=nido_session

# === Database (optional) ===
# DATABASE_URL=postgresql://user:password@localhost:5432/nido

# App origin (used for WebAuthn passkey registration)
# Must match the URL users access the app from
APP_ORIGIN=http://localhost:3100
# Optional: comma-separated email allowlist for invitations
# ALLOWED_EMAILS=samuel@example.com,maria@example.com

# === Security Notes ===
# 1. NEVER commit .env file to version control
# 2. In production, use environment variables or secret management
# 3. Rotate secrets periodically in production
