# Nido Environment Configuration
# Copy this file to .env and fill in values

# === Required for all environments ===

# JWT Secret for signing authentication tokens
# Must be at least 32 characters long
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-secret-minimum-32-chars

# === Development defaults (optional in dev) ===

# Default password for initial users (samuel, maria)
# Must be at least 8 characters long
# In production, either set this or ensure users already exist
DEFAULT_PASSWORD=change-me-to-a-strong-password

# === Server configuration ===

# Node environment: development, production, test
NODE_ENV=development

# Port to run the server on
PORT=3100

# === Database (optional) ===
# If using PostgreSQL or other database, set connection URL
# DATABASE_URL=postgresql://user:password@localhost:5432/nido

# === Security Notes ===
# 
# 1. NEVER commit .env file to version control
# 2. In production, use environment variables or secret management
# 3. Generate strong secrets:
#    - JWT_SECRET: openssl rand -hex 32
#    - DEFAULT_PASSWORD: openssl rand -hex 16
# 4. Rotate secrets periodically in production
# 5. For production, consider using:
#    - HashiCorp Vault
#    - AWS Secrets Manager
#    - Azure Key Vault
#    - Or at least encrypted environment variables