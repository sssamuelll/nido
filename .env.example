# Nido Environment Configuration
# Copy this file to .env and fill in values

# === Required for all environments ===

# JWT Secret for signing authentication tokens
# Must be at least 32 characters long and not the example placeholder
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-random-64-char-secret

# === Development defaults (optional in dev) ===

# Default password for initial legacy users (samuel, maria)
# Only used by the temporary fallback login path while auth-v2 rolls out
DEFAULT_PASSWORD=replace-with-a-strong-password

# === Server configuration ===

NODE_ENV=development
PORT=3100
APP_BASE_URL=http://localhost:3100
APP_SESSION_DAYS=30
APP_SESSION_COOKIE_NAME=nido_session

# === Database (optional) ===
# DATABASE_URL=postgresql://user:password@localhost:5432/nido

# === Supabase Auth V2 (optional but required for magic links) ===
# When these are missing, Nido keeps the legacy username/password login visible
# and /api/auth/magic-link/* stays disabled.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
# Comma-separated allowlist for magic-link auth. Only these emails can request a link
# and exchange the Supabase session for a Nido session.
MAGIC_LINK_ALLOWED_EMAILS=samuel@example.com,maria@example.com
# Optional: use this if you want backend verification/admin flows with elevated access.
SUPABASE_SERVICE_ROLE_KEY=

# === Supabase dashboard setup notes ===
# 1. Enable Email provider in Authentication > Providers.
# 2. Configure your Site URL / redirect allow list to include:
#    - http://localhost:3100/auth/callback
#    - https://your-production-domain/auth/callback
# 3. Create real auth users for Samuel and Maria in Supabase Auth.
# 4. Set MAGIC_LINK_ALLOWED_EMAILS to Samuel and Maria's exact auth emails.
# 5. Magic-link callback lands in the SPA, which exchanges the Supabase access token
#    for a server-side HttpOnly app session cookie.

# === Security Notes ===
# 1. NEVER commit .env file to version control
# 2. In production, use environment variables or secret management
# 3. Rotate secrets periodically in production
